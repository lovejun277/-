   "source": [
    "# 假设你有一个名为 df 的 DataFrame，包含 '病人编码' 和 '项目名称' 列\n",
    "\n",
    "# 使用 str.contains() 方法筛选出包含'a'、'b'和'c'值的项目名称的行\n",
    "\n",
    "filtered_df = df[(df['项目名称'] == \"重症监护\") | df['项目名称'].str.contains('空调费')]\n",
    "\n",
    "sorted_result_df = filtered_df.sort_values(by=['病人编码','操作日期'])\n",
    "# 输出筛选后的结果\n",
    "show(sorted_result_df)"
   ]
  }
 ],
